# Groq LLaMA 3.3 70B  →  https://console.groq.com  (free tier available)
GROQ_API_KEY=gsk_YOUR_KEY_HERE

PORT=3001
NODE_ENV=development
RATE_LIMIT_MAX=100
ALLOWED_ORIGINS=*
